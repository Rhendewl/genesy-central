# ─────────────────────────────────────────────────────────────────────────────
# Lancaster SaaS — Variáveis de Ambiente
# 1. Copie este arquivo: cp .env.local.example .env.local
# 2. Preencha os valores abaixo com as credenciais do seu projeto Supabase
#    (Supabase Dashboard > Project Settings > API)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Meta Ads Integration ───────────────────────────────────────────────────────
# Obtenha em: https://developers.facebook.com > Seu App > Configurações Básicas

# ID público do app Meta (pode aparecer no front-end — usado na URL do OAuth)
NEXT_PUBLIC_META_APP_ID=your-meta-app-id

# Segredo do app (NUNCA exponha no front-end — somente server-side)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Chave de criptografia dos tokens OAuth (32 bytes = 64 chars hex)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key

# URL pública do app (usada como base para o redirect_uri do OAuth)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Meta Lead Ads Webhook ──────────────────────────────────────────────────────
# Token de verificação do webhook (você define — use qualquer string aleatória segura)
# Configure também no painel Meta: App > Webhooks > Verify Token
META_VERIFY_TOKEN=your-random-verify-token

# ── Supabase Service Role ──────────────────────────────────────────────────────
# Chave de serviço para o handler de webhook (bypassa RLS)
# Supabase Dashboard > Project Settings > API > service_role key
# NUNCA exponha no front-end (sem NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
